# ---------------------------------------------------------------------------
# Knit environment. Copy to .env and fill in. NEVER commit the real .env.
# ---------------------------------------------------------------------------

# Postgres (Railway provisions this automatically as DATABASE_URL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/knit?schema=public"

# API
API_PORT=4000
NODE_ENV=development

# Web -> API base URL (used by the Next.js app)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- Integrations to wire later (left blank in the scaffold) ---
# Payments (creator-layer paid rentals + the $10 Plus subscription)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# AI styling assistant (closet concierge) — added at build step 7
ANTHROPIC_API_KEY=""
