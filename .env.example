# ---------------------------------------------------------------------------
# Knit environment. Copy to .env and fill in. NEVER commit the real .env.
# ---------------------------------------------------------------------------

# Postgres (Railway provisions this automatically as DATABASE_URL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/knit?schema=public"

# API
API_PORT=4000
NODE_ENV=development

# Web -> API base URL (used by the Next.js app)
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- Integrations ---
# Payments (creator-layer paid rentals + the $10 Plus subscription).
# Leave STRIPE_SECRET_KEY blank to run the SIMULATED payments provider — the
# whole paid-rent flow (authorize / capture / refund + Connect payouts) works
# without live keys. Drop in test keys (sk_test_…) to use real Stripe.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Platform take rate on creator-layer rentals, in basis points (1500 = 15%).
PLATFORM_FEE_BPS=1500
# Where Stripe Connect onboarding returns to.
WEB_URL="http://localhost:3000"

# AI styling assistant (closet concierge) — added at build step 7
ANTHROPIC_API_KEY=""
