{
  "name": "drobe",
  "version": "0.0.1",
  "private": true,
  "description": "Drobe — a social closet network. See what's in your friends' and favorite creators' closets, and rent, buy, or give away the actual pieces.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @drobe/db generate",
    "db:migrate": "pnpm --filter @drobe/db migrate",
    "db:push": "pnpm --filter @drobe/db push",
    "db:studio": "pnpm --filter @drobe/db studio",
    "db:seed": "pnpm --filter @drobe/db seed",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
