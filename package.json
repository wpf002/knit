{
  "name": "knit",
  "version": "0.0.1",
  "private": true,
  "description": "Knit — a social closet network. See what's in your friends' and favorite creators' closets, and rent, buy, or give away the actual pieces.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "dotenv -e .env -- turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @knit/db generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @knit/db migrate",
    "db:push": "dotenv -e .env -- pnpm --filter @knit/db push",
    "db:studio": "dotenv -e .env -- pnpm --filter @knit/db studio",
    "db:seed": "dotenv -e .env -- pnpm --filter @knit/db seed",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
